<UserControl x:Class="magal.Views.GerenciamentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="AeroAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroTextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder" Color="#F1F5F9"/>

        <Style x:Key="KpiCardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="200"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20" Padding="35">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="25" ShadowDepth="2" Opacity="0.05" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconBg" Width="90" Height="90" CornerRadius="45" Background="#F0F7FF" VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="25,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AzulAero}"/>
                                    <TextBlock Text="{Binding ToolTip, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="15" Foreground="{StaticResource AeroTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="22"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource AeroAccent}" VerticalAlignment="Center" Opacity="0.8"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AeroAccent}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.12" Color="#3B82F6"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="IconBg" Property="Background" Value="#E1EFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="80" Margin="0,0,0,10">
            <TextBlock Text="Central de Gerenciamento"
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="{StaticResource AzulAero}"
                       VerticalAlignment="Center"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4">
            <Border Style="{StaticResource KpiCardBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="FUNCIONÁRIOS" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalFuncionarios, FallbackValue='24'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CLIENTES" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalClientes, FallbackValue='112'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CARGOS DEFINIDOS" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalCargos, FallbackValue='08'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="CUSTOS OPERACIONAIS"
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalCustos, FallbackValue='15'}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <UniformGrid Columns="2" VerticalAlignment="Top">
                <Button Style="{StaticResource CardButtonStyle}"
                        Content="👥" 
                        Tag="Funcionários"
                        ToolTip="Gerencie os funcionários, dados pessoais, contratos e informações profissionais." 
                        Click="BtnFuncionarios_Click"/>
                
                <Button Style="{StaticResource CardButtonStyle}" 
                        Content="💼" 
                        Tag="Cargos" 
                        ToolTip="Cadastre e gerencie os cargos da empresa, salários e atribuições." 
                        Click="BtnCargos_Click"/>
                
                <Button Style="{StaticResource CardButtonStyle}"
                        Content="🏢" 
                        Tag="Clientes" 
                        ToolTip="Gerencie os clientes, contatos, endereços e informações comerciais."/>
                
                <Button Style="{StaticResource CardButtonStyle}" 
                        Content="💰" 
                        Tag="Custos" 
                        ToolTip="Gerencie os custos diretos e indiretos utilizados nos orçamentos."/>
            </UniformGrid>
        </ScrollViewer>
    </Grid>
</UserControl>