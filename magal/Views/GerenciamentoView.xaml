<UserControl x:Class="magal.Views.GerenciamentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.expression/blend/2008"
             mc:Ignorable="d" 
             Language="pt-BR"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F8FAFC"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="AeroAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroTextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder" Color="#F1F5F9"/>

        <Style x:Key="KpiCardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="200"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20" Padding="35">
                            <Border.Effect>
                                <DropShadowEffect x:Name="CardShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.04" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="IconBg" Width="90" Height="90" CornerRadius="45" Background="#F8FAFC" VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="25,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AzulAero}"/>
                                    <TextBlock Text="{Binding Uid, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="15" Foreground="{StaticResource AeroTextMuted}" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="22"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource AeroAccent}" VerticalAlignment="Center" Opacity="0.6"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#F0F4FA" Duration="0:0:0.12"/>
                                            <ColorAnimation Storyboard.TargetName="IconBg" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#E2EBF5" Duration="0:0:0.12"/>

                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="28" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.10" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)" To="5" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="White" Duration="0:0:0.12"/>
                                            <ColorAnimation Storyboard.TargetName="IconBg" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#F8FAFC" Duration="0:0:0.12"/>

                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="20" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.04" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)" To="2" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="80" Margin="0,0,0,10">
            <TextBlock Text="Central de Gerenciamento"
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="{StaticResource AzulAero}"
                       VerticalAlignment="Center"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4">
            <Border Style="{StaticResource KpiCardBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="FUNCIONÁRIOS" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalFuncionarios, FallbackValue='24'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CLIENTES" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalClientes, FallbackValue='112'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CARGOS DEFINIDOS" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalCargos, FallbackValue='08'}"
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCardBorder}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="CUSTOS OPERACIONAIS"
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AeroTextHint}" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalCustos, FallbackValue='15'}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <UniformGrid Columns="2" VerticalAlignment="Top">
                <Button Style="{StaticResource CardButtonStyle}"
                        Content="👥" 
                        Tag="Funcionários"
                        Uid="Gerencie os funcionários, dados pessoais, contratos e informações profissionais." 
                        Click="BtnFuncionarios_Click"/>

                <Button Style="{StaticResource CardButtonStyle}" 
                        Content="💼" 
                        Tag="Cargos" 
                        Uid="Cadastre e gerencie os cargos da empresa, salários e atribuições." 
                        Click="BtnCargos_Click"/>

                <Button Style="{StaticResource CardButtonStyle}"
                        Content="🏢" 
                        Tag="Clientes" 
                        Uid="Gerencie os clientes, contatos, endereços e informações comerciais."
                        Click="BtnClientes_Click"/>

                <Button Style="{StaticResource CardButtonStyle}" 
                        Content="💰" 
                        Tag="Custos" 
                        Uid="Gerencie os custos diretos e indiretos utilizados nos orçamentos."
                        Click="BtnCustos_Click"/>
            </UniformGrid>
        </ScrollViewer>
    </Grid>
</UserControl>