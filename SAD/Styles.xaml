<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:SAD.Helpers">

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#777777"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#333333"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

    <!-- TextBox Styles -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Padding" Value="6"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PercentTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
    </Style>

    <!-- Button Styles -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="#1E3A5F"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background" Value="#2E7D32"/>
    </Style>

    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background" Value="#C0392B"/>
    </Style>

    <!-- Card Style -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- Label Caption -->
    <Style x:Key="LabelCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#555555"/>
    </Style>

    <!-- Total Final Label -->
    <Style x:Key="TotalFinalLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#1E3A5F"/>
    </Style>

    <!-- Converters -->
    <conv:CurrencyConverter x:Key="CurrencyConverter"/>

</ResourceDictionary>