<Window x:Class="SAD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SAD.ViewModels"
        Title="SAD — Sistema de Apoio à Decisão · Precificação de Projetos"
        Height="820" Width="1180"
        MinHeight="680" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>       <!-- Header -->
            <RowDefinition Height="*"/>        <!-- Conteúdo -->
            <RowDefinition Height="32"/>       <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 0 — HEADER
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Ícone decorativo -->
                    <Border Width="36" Height="36" Background="#2E86C1" CornerRadius="8"
                            Margin="0,0,12,0">
                        <TextBlock Text="$" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SAD · Precificação de Engenharia"
                                   FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Sistema de Apoio à Decisão"
                                   FontSize="10" Foreground="#8AB4D4"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           FontSize="11" Foreground="#8AB4D4"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dd/MM/yyyy', Mode=OneTime}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 1 — CONTEÚDO PRINCIPAL
             ════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- ── COLUNA ESQUERDA (dados + tabela) ─────────────────── -->
                <StackPanel Grid.Column="0" Margin="0,0,0,16">

                    <!-- Card: Dados do Cliente -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="DADOS DA PROPOSTA"
                                       Style="{StaticResource LabelCaption}"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Cliente" Style="{StaticResource LabelCaption}"/>
                                    <TextBox Text="{Binding Cliente, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             MaxLength="100"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Nome do Projeto" Style="{StaticResource LabelCaption}"/>
                                    <TextBox Text="{Binding Projeto, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             MaxLength="150"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Card: Tabela de cargos -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Título + botão adicionar -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="COMPOSIÇÃO DO PROJETO"
                                           Style="{StaticResource LabelCaption}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+ Adicionar Cargo"
                                        Style="{StaticResource BtnPrimary}"
                                        Command="{Binding AdicionarItemCommand}"
                                        Height="34" FontSize="12"/>
                            </Grid>

                            <!-- DataGrid principal -->
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Itens}"
                                      MinHeight="200">

                                <DataGrid.Columns>

                                    <!-- Cargo -->
                                    <DataGridTextColumn Header="Cargo / Função"
                                                        Binding="{Binding Cargo, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*" MinWidth="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Horas -->
                                    <DataGridTextColumn Header="Horas"
                                                        Binding="{Binding Horas, UpdateSourceTrigger=PropertyChanged, StringFormat='0.#'}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Valor por hora -->
                                    <DataGridTextColumn Header="Valor / Hora"
                                                        Binding="{Binding ValorPorHora, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource CurrencyConverter}}"
                                                        Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,12,0"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Total calculado (read-only) -->
                                    <DataGridTextColumn Header="Total"
                                                        Binding="{Binding Total, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                                        Width="140"
                                                        IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,12,0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Botão remover -->
                                    <DataGridTemplateColumn Header="" Width="60" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕"
                                                        FontSize="12"
                                                        Width="32" Height="28"
                                                        Foreground="#C0392B"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.RemoverItemCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Subtotal abaixo da tabela -->
                            <Border Grid.Row="4" Background="#F0F4FA" CornerRadius="8" Padding="16,10">
                                <Grid>
                                    <TextBlock Text="SUBTOTAL (HORAS × VALOR)"
                                               Style="{StaticResource LabelCaption}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>

                </StackPanel>

                <!-- ── COLUNA DIREITA (parâmetros + totais + ações) ──────── -->
                <StackPanel Grid.Column="2" Margin="0,0,0,16">

                    <!-- Card: Parâmetros financeiros -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="PARÂMETROS FINANCEIROS"
                                       Style="{StaticResource LabelCaption}"
                                       Margin="0,0,0,16"/>

                            <!-- Overhead -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Overhead (%)" Style="{StaticResource LabelCaption}"/>
                                    <TextBlock Text="Custos indiretos da operação"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OverheadPercentual, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PercentTextBox}"
                                         VerticalAlignment="Top"/>
                            </Grid>

                            <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                            <!-- Lucro -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Margem de Lucro (%)" Style="{StaticResource LabelCaption}"/>
                                    <TextBlock Text="Lucro sobre custo + overhead"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding LucroPercentual, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PercentTextBox}"
                                         VerticalAlignment="Top"/>
                            </Grid>

                            <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                            <!-- Impostos -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Impostos (%)" Style="{StaticResource LabelCaption}"/>
                                    <TextBlock Text="ISS/PIS/COFINS (estimativa)"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding ImpostosPercentual, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PercentTextBox}"
                                         VerticalAlignment="Top"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Card: Resumo financeiro -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="RESUMO FINANCEIRO"
                                       Style="{StaticResource LabelCaption}"
                                       Margin="0,0,0,12"/>

                            <!-- Linhas de resumo -->
                            <ItemsControl>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Valor}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Subtotal -->
                            <Grid Margin="0,6">
                                <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Overhead -->
                            <Grid Margin="0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Overhead" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding OverheadPercentual, StringFormat=' ({0:0.#}%)'}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ValorOverhead, Converter={StaticResource CurrencyConverter}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Lucro -->
                            <Grid Margin="0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Margem de Lucro" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding LucroPercentual, StringFormat=' ({0:0.#}%)'}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ValorLucro, Converter={StaticResource CurrencyConverter}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Impostos -->
                            <Grid Margin="0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Impostos" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ImpostosPercentual, StringFormat=' ({0:0.#}%)'}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ValorImpostos, Converter={StaticResource CurrencyConverter}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Background="{StaticResource BorderBrush}" Margin="0,10"/>

                            <!-- Total Final — destaque -->
                            <Border Background="{StaticResource PrimaryBrush}"
                                    CornerRadius="10" Padding="16,14">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="VALOR TOTAL DA PROPOSTA"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#8AB4D4" LetterSpacing="0.5"/>
                                        <TextBlock Text="{Binding TotalFinal, Converter={StaticResource CurrencyConverter}}"
                                                   Style="{StaticResource TotalFinalLabel}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- Card: Ações -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="AÇÕES" Style="{StaticResource LabelCaption}" Margin="0,0,0,12"/>

                            <Button Content="📄  Gerar Proposta em PDF"
                                    Style="{StaticResource BtnSuccess}"
                                    Command="{Binding GerarPdfCommand}"
                                    Height="44" FontSize="14" Margin="0,0,0,8"/>

                            <Button Content="🗑  Limpar Tudo"
                                    Style="{StaticResource BtnDanger}"
                                    Command="{Binding LimparCommand}"
                                    Height="38" FontSize="12"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════════
             ROW 2 — STATUS BAR
             ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource PrimaryBrush}" Padding="16,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="#8AB4D4"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
