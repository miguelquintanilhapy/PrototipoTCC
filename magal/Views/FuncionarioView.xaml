<UserControl x:Class="magal.Views.FuncionarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Language="pt-BR"
             d:DesignHeight="900"
             d:DesignWidth="1200"
             Background="#F0F4FA">

    <UserControl.Resources>

        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="AeroAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroDanger" Color="#EF4444"/>
        <SolidColorBrush x:Key="AeroTextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="VerdeAero" Color="#009140"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AzulAero}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,7">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#1E3A8A"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="32,28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <Grid Grid.Row="0"
      Height="80"
      Margin="0,0,0,15">

            <TextBlock Text="Funcionários"
               FontSize="28"
               FontWeight="Bold"
               Foreground="{StaticResource AzulAero}"
               VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

                <Button Content="+ NOVO FUNCIONÁRIO"
                Style="{StaticResource PrimaryBtn}"
                Margin="0,0,10,0"
                Command="{Binding CriarCommand}"/>

                <Button Content="ATUALIZAR LISTA"
                Style="{StaticResource PrimaryBtn}"
                Command="{Binding AtualizarCommand}"/>

            </StackPanel>
        </Grid>

        <!-- PESQUISA -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,15">

            <TextBlock Text="FILTRE POR NOME, VÍNCULO OU STATUS"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="{StaticResource AzulAero}"
                       Margin="0,0,0,4"/>

            <Grid>

                <TextBox Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"

                         Height="38"
                         VerticalContentAlignment="Center"
                         Padding="12,0,40,0"
                         FontSize="14"
                         Background="White"
                         BorderThickness="1"
                         BorderBrush="{StaticResource AeroBorder}">

                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius"
                                    Value="8"/>
                        </Style>
                    </TextBox.Resources>

                </TextBox>

                <TextBlock Text="🔍"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Foreground="{StaticResource AeroTextHint}"/>

            </Grid>
        </StackPanel>

        <!-- TABELA -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="16"
                BorderThickness="1"
                BorderBrush="{StaticResource AeroBorder}"
                Padding="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding FuncionariosView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          HeadersVisibility="Column"
                          RowHeight="45">

                    <DataGrid.Resources>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"
                                    Value="#F8FAFC"/>

                            <Setter Property="Foreground"
                                    Value="{StaticResource AeroTextMuted}"/>

                            <Setter Property="FontWeight"
                                    Value="SemiBold"/>

                            <Setter Property="Padding"
                                    Value="15,10"/>

                            <Setter Property="BorderThickness"
                                    Value="0,0,0,1"/>

                            <Setter Property="BorderBrush"
                                    Value="{StaticResource AeroBorder}"/>
                        </Style>

                        <Style TargetType="DataGridCell">

                            <Setter Property="Padding"
                                    Value="15,0"/>

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="DataGridCell">

                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">

                                            <ContentPresenter VerticalAlignment="Center"/>

                                        </Border>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                            <Style.Triggers>

                                <Trigger Property="IsSelected"
                                         Value="True">

                                    <Setter Property="Background"
                                            Value="#EFF6FF"/>

                                    <Setter Property="Foreground"
                                            Value="{StaticResource AzulAero}"/>

                                </Trigger>

                            </Style.Triggers>

                        </Style>

                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding id_funcionario}"
                                            Width="80"
                                            FontWeight="SemiBold"/>

                        <DataGridTextColumn Header="NOME"
                                            Binding="{Binding nome}"
                                            Width="*"
                                            FontWeight="SemiBold"/>

                        <DataGridTextColumn Header="CUSTO/HORA"
                                            Binding="{Binding custo_hora, StringFormat='{}{0:C}'}"
                                            Width="160">

                            <DataGridTextColumn.ElementStyle>

                                <Style TargetType="TextBlock">

                                    <Setter Property="HorizontalAlignment"
                                            Value="Right"/>

                                    <Setter Property="VerticalAlignment"
                                            Value="Center"/>

                                    <Setter Property="Foreground"
                                            Value="{StaticResource VerdeAero}"/>

                                    <Setter Property="Padding"
                                            Value="0,0,40,0"/>

                                </Style>

                            </DataGridTextColumn.ElementStyle>

                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TIPO VÍNCULO"
                                            Binding="{Binding tipo_vinculo}"
                                            Width="170"/>

                        <DataGridTextColumn Header="STATUS"
                                            Binding="{Binding status}"
                                            Width="120"
                                            FontWeight="SemiBold"/>

                        <DataGridTemplateColumn Header="AÇÕES"
                                                Width="150">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal">

                                        <Button Content="Editar"
                                                Foreground="{StaticResource AeroAccent}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontWeight="Bold"
                                                Margin="0,0,12,0"/>

                                        <Button Content="Excluir"
                                                Command="{Binding DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{StaticResource AeroDanger}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontWeight="Bold"/>

                                    </StackPanel>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- RODAPÉ -->
                <Border Grid.Row="1"
                        Background="#F8FAFC"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#F1F5F9"
                        CornerRadius="0,0,16,16"
                        Padding="20,12">

                    <TextBlock Text="{Binding FuncionariosView.Count, StringFormat='{}{0} funcionários encontrados'}"
                               FontSize="12"
                               Foreground="{StaticResource AeroTextHint}"
                               VerticalAlignment="Center"/>

                </Border>

            </Grid>

        </Border>

    </Grid>
</UserControl>