<UserControl x:Class="magal.Views.GerenciamentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel Grid.Row="0">

            <Border Background="#1E3A8A"
                    CornerRadius="8"
                    Padding="10,4"
                    HorizontalAlignment="Left">

                <TextBlock Text="AERO CONCEPTS v2.0"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="12"/>
            </Border>

            <TextBlock Text="Central de Gerenciamento"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,15,0,5"/>

            <TextBlock Text="Gerencie funcionários, cargos, clientes e custos do sistema"
                       FontSize="16"
                       Foreground="#64748B"/>
        </StackPanel>

        <!-- CARDS -->
        <UniformGrid Grid.Row="2"
                     Columns="2"
                     Rows="2"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="40">

            <!-- FUNCIONÁRIOS -->
            <Button Width="220"
                    Height="140"
                    Margin="15"
                    BorderThickness="0"
                    Background="White"
                    Cursor="Hand"
                    Click="BtnFuncionarios_Click">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="20">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="👤"
                                           FontSize="42"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Funcionários"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>

                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- CARGOS -->
            <Button Width="220"
                    Height="140"
                    Margin="15"
                    BorderThickness="0"
                    Background="White"
                    Cursor="Hand">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="20">

                            <StackPanel>

                                <TextBlock Text="💼"
                                           FontSize="42"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Cargos"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>

                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- CLIENTES -->
            <Button Width="220"
                    Height="140"
                    Margin="15"
                    BorderThickness="0"
                    Background="White"
                    Cursor="Hand">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="20">

                            <StackPanel>

                                <TextBlock Text="🏢"
                                           FontSize="42"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Clientes"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>

                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- CUSTOS -->
            <Button Width="220"
                    Height="140"
                    Margin="15"
                    BorderThickness="0"
                    Background="White"
                    Cursor="Hand">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="20">

                            <StackPanel>

                                <TextBlock Text="💰"
                                           FontSize="42"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Custos"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>

                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </UniformGrid>

    </Grid>
</UserControl>