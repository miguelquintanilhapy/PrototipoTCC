<Window x:Class="magal.Views.EditarUsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Usuário"
        Height="680"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4FA">

    <Window.Resources>
        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="AeroBorder" Color="#E2E8F0"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AzulAero}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                BorderBrush="{StaticResource AeroBorder}"
                                BorderThickness="1.5"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd"
                                BorderBrush="{StaticResource AeroBorder}"
                                BorderThickness="1.5"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
            <Setter Property="BorderThickness" Value="0.4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AzulAero}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="32,28">
        <TextBlock Text="Editar Usuário"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource AzulAero}"
                   Margin="0,0,0,24"/>

        <TextBlock Text="NOME COMPLETO"
                   Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtNome"
                 Style="{StaticResource InputStyle}"
                 Margin="0,0,0,14"/>

        <TextBlock Text="E-MAIL DE ACESSO"
                   Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtEmail"
                 Style="{StaticResource InputStyle}"
                 Margin="0,0,0,14"/>

        <TextBlock Text="SENHA ATUAL (OBRIGATÓRIA PARA SALVAR)"
                   Style="{StaticResource LabelStyle}"/>
        <PasswordBox x:Name="TxtSenhaAtual"
                     Style="{StaticResource PasswordInputStyle}"
                     Margin="0,0,0,14"/>

        <TextBlock Text="NOVA SENHA (DEIXE EM BRANCO PARA NÃO ALTERAR)"
                   Style="{StaticResource LabelStyle}"/>
        <PasswordBox x:Name="TxtSenhaNova"
                     Style="{StaticResource PasswordInputStyle}"
                     Margin="0,0,0,14"/>

        <TextBlock Text="NÍVEL DE ACESSO"
                   Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="ComboNivel"
                  Style="{StaticResource ComboStyle}"
                  Margin="0,0,0,14"
                  FontWeight="SemiBold">
            <ComboBoxItem Content="Operador"/>
            <ComboBoxItem Content="Administrador"/>
        </ComboBox>

        <TextBlock Text="STATUS DO USUÁRIO"
                   Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="ComboStatus"
                  Style="{StaticResource ComboStyle}"
                  Margin="0,0,0,24"
                  FontWeight="SemiBold">
            <ComboBoxItem Content="Ativo"/>
            <ComboBoxItem Content="Inativo"/>
        </ComboBox>

        <Button Content="SALVAR ALTERAÇÕES"
                Style="{StaticResource PrimaryBtn}"
                Click="BtnSalvar_Click"/>
    </StackPanel>
</Window>