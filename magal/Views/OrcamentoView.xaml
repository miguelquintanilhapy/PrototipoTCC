<UserControl x:Class="magal.Views.OrcamentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F0F4FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AeroPrimary"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="AeroAccent"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroDanger"     Color="#EF4444"/>
        <SolidColorBrush x:Key="AeroTextDark"   Color="#0F172A"/>
        <SolidColorBrush x:Key="AeroTextMuted"  Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder"     Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLight"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AeroCardBg"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="AeroCardBorder" Color="#E8EEF8"/>
        <SolidColorBrush x:Key="AeroPillBg"     Color="#EFF6FF"/>
        <SolidColorBrush x:Key="AeroPillFg"     Color="#1D4ED8"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AeroPrimary}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1e40af"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AeroTextMuted}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                        CornerRadius="8" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconDeleteBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="{StaticResource AeroDanger}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AeroBorder}"/>
            <Setter Property="Background"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="{StaticResource AeroTextDark}"/>
        </Style>

        <Style x:Key="CleanCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="bg" Background="{TemplateBinding Background}" 
                                CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}"/>
                            <ContentPresenter x:Name="ContentSite" 
                  IsHitTestVisible="False" 
                  Content="{TemplateBinding SelectionBoxItem}" 
                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" Margin="10,0,30,0" 
                  VerticalAlignment="Center"/>
                            <ToggleButton Background="Transparent" BorderThickness="0" 
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Path Data="M0,0 L4,4 L8,0" Stroke="{StaticResource AeroTextMuted}" 
                              StrokeThickness="2" HorizontalAlignment="Right" 
                              Margin="0,0,12,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True">
                                <Border Background="White" CornerRadius="8" BorderThickness="1" 
                                    BorderBrush="{StaticResource AeroBorder}" MinWidth="{TemplateBinding ActualWidth}">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AeroAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource AeroCardBg}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource AeroCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="16,14"/>
            <Setter Property="Margin"         Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#93C5FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CostCard" TargetType="Border" BasedOn="{StaticResource TaskCard}"/>

    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,24">

            <!-- Título -->
            <StackPanel VerticalAlignment="Center">
                <Border Background="{StaticResource AeroPrimary}" CornerRadius="4"
                        HorizontalAlignment="Left" Padding="8,3" Margin="0,0,0,8">
                    <TextBlock Text="AERO CONCEPTS v2.0" Foreground="White"
                               FontSize="9" FontWeight="Black"/>
                </Border>
                <TextBlock Text="Gestão de Orçamentos" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource AeroTextDark}"/>
            </StackPanel>

            <!-- Card projeto + cliente -->
            <Border Background="White" CornerRadius="14" Padding="18,14"
                    HorizontalAlignment="Right" MinWidth="400"
                    BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="NOME DO PROJETO" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AeroTextHint}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ProjetoAtual.Nome, UpdateSourceTrigger=PropertyChanged}"
                                 FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{StaticResource AeroBorder}" Width="1" Margin="0,2"/>

                    <StackPanel Grid.Column="2" Margin="16,0,0,0">
                        <TextBlock Text="CLIENTE" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AeroTextHint}"
                                   Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Clientes}"
                                  DisplayMemberPath="Nome"
                                  SelectedItem="{Binding ProjetoAtual.Cliente}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--SEÇÕES-->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--SEÇÃO 1: MÃO DE OBRA  -->
                <Border Background="White" CornerRadius="16" Margin="0,0,0,16"
        BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel>

                        <Grid Margin="20,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AeroPrimary}" CornerRadius="6"
                        Width="24" Height="24" Margin="0,0,10,0">
                                    <TextBlock Text="1" Foreground="White" FontSize="11"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="COMPOSIÇÃO DE MÃO DE OBRA" FontSize="11"
                           FontWeight="Bold" Foreground="{StaticResource AeroTextMuted}"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="+ ADICIONAR ETAPA"
                    Command="{Binding AdicionarTarefaCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9"/>

                        <ItemsControl ItemsSource="{Binding ProjetoAtual.Tarefas}"
                      Margin="20,14,20,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TaskCard}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="5,0">
                                                <TextBlock Text="HORAS" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding HorasEstimadas, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="16" FontWeight="Black" 
                                         Foreground="{StaticResource AeroPrimary}"
                                         Background="#F8FAFC" BorderThickness="0"
                                         HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="DESCRIÇÃO DA ETAPA" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" FontWeight="SemiBold"
                                         Foreground="{StaticResource AeroTextDark}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="0,2"/>
                                                <Border Height="1" Background="{StaticResource BorderLight}" Opacity="0.5"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="RESPONSÁVEL" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,2"/>
                                                <ComboBox ItemsSource="{Binding DataContext.Funcionarios, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Funcionario, Mode=TwoWay}"
                                          DisplayMemberPath="Nome"
                                          Style="{StaticResource CleanCombo}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                                                <TextBlock Text="SUBTOTAL" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding CustoReal, StringFormat=C}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AeroTextDark}"/>
                                            </StackPanel>

                                            <Button Grid.Column="4" Content="✕"
                                    Command="{Binding DataContext.DeletarTarefaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconDeleteBtn}"
                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#F8FAFC" BorderThickness="0,1,0,0"
                BorderBrush="#F1F5F9" CornerRadius="0,0,16,16"
                Padding="20,12">
                            <Grid>
                                <TextBlock Text="{Binding ProjetoAtual.Tarefas.Count, StringFormat='{}{0} etapas ativas'}"
                           FontSize="12" Foreground="{StaticResource AeroTextHint}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!--  SEÇÃO 2: EQUIPAMENTOS  -->
                <Border Background="White" CornerRadius="16" Margin="0,0,0,8"
        BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel>

                        <Grid Margin="20,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#64748B" CornerRadius="6"
                        Width="24" Height="24" Margin="0,0,10,0">
                                    <TextBlock Text="2" Foreground="White" FontSize="11"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="EQUIPAMENTOS E INSUMOS" FontSize="11"
                           FontWeight="Bold" Foreground="{StaticResource AeroTextMuted}"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="+ CUSTO EXTRA"
                    Command="{Binding AdicionarCustoCommand}"
                    Style="{StaticResource SecondaryBtn}"
                    HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9"/>

                        <ItemsControl ItemsSource="{Binding CustosExtras}"
                      Margin="20,14,20,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CostCard}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="5,0,15,0">
                                                <TextBlock Text="DESCRIÇÃO DO CUSTO" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" FontWeight="SemiBold"
                                         Foreground="{StaticResource AeroTextDark}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="0,2"/>
                                                <Border Height="1" Background="{StaticResource BorderLight}" Opacity="0.5"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="CATEGORIA" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding Categoria, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Foreground="{StaticResource AeroTextMuted}"
                                         Background="#F8FAFC" BorderThickness="0" >
                                                    
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="VALOR (R$)" FontSize="9" FontWeight="Bold" 
                                           Foreground="{StaticResource AeroTextHint}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding Valor, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                         FontSize="15" FontWeight="Bold" 
                                         Foreground="{StaticResource AeroTextDark}"
                                         Background="Transparent" BorderThickness="0"
                                         HorizontalContentAlignment="Right" Padding="0,2"/>
                                                <Border Height="1" Background="{StaticResource BorderLight}" HorizontalAlignment="Right" Width="100" Opacity="0.5"/>
                                            </StackPanel>

                                            <Button Grid.Column="3" Content="✕"
                                    Command="{Binding DataContext.DeletarCustoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconDeleteBtn}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#F8FAFC" BorderThickness="0,1,0,0"
                BorderBrush="#F1F5F9" CornerRadius="0,0,16,16"
                Padding="20,12">
                            <Grid>
                                <TextBlock Text="{Binding CustosExtras.Count, StringFormat='{}{0} itens de custo'}"
                           FontSize="12" Foreground="{StaticResource AeroTextHint}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 
             RODAPÉ — TOTAIS E FINALIZAR
         -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Lucro + Impostos -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                <Border Background="White" CornerRadius="10" Padding="14,10"
                        Margin="0,0,10,0" BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LUCRO" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AeroTextHint}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding ProjetoAtual.Orcamento.MargemPercentual,
                                          UpdateSourceTrigger=PropertyChanged}"
                                 Width="40" BorderThickness="0" FontWeight="Bold"
                                 FontSize="14" HorizontalContentAlignment="Center"
                                 Background="Transparent" Padding="0"/>
                        <TextBlock Text="%" Foreground="{StaticResource AeroTextMuted}"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="14,10"
                        BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="IMPOSTOS" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AeroTextHint}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding ProjetoAtual.Orcamento.PercentualImpostos,
                                          UpdateSourceTrigger=PropertyChanged}"
                                 Width="40" BorderThickness="0" FontWeight="Bold"
                                 FontSize="14" HorizontalContentAlignment="Center"
                                 Background="Transparent" Padding="0"/>
                        <TextBlock Text="%" Foreground="{StaticResource AeroTextMuted}"
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Total + Botão finalizar -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel VerticalAlignment="Center" Margin="0,0,28,0">
                    <TextBlock Text="TOTAL DA PROPOSTA" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AeroTextHint}"
                               HorizontalAlignment="Right" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ProjetoAtual.Orcamento.ValorFinal, StringFormat=C}"
                               FontSize="36" FontWeight="Black"
                               Foreground="{StaticResource AeroPrimary}"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <Button Content="FINALIZAR PROPOSTA"
                        Command="{Binding GerarPdfCommand}"
                        IsEnabled="{Binding BotaoAtivo}"
                        Style="{StaticResource PrimaryBtn}"
                        Width="240" Height="54" FontSize="14"/>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
