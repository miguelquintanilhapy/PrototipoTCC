<Window x:Class="magal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=" AERO Concepts - Sistema de Apoio a Decisão " Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC">

    <Window.Resources>
        <SolidColorBrush x:Key="AzulOriginalSide" Color="#0F172A"/>
        <SolidColorBrush x:Key="CinzaAero" Color="#ACACAC"/>
        <SolidColorBrush x:Key="AzulHover" Color="#1E293B"/>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource CinzaAero}"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AzulHover}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border Background="{StaticResource AzulOriginalSide}"/>

            <StackPanel Margin="0,202,0,0">
                <Button x:Name="BtnHome" 
        Content="Home" 
        FontWeight="SemiBold" 
        Style="{StaticResource MenuButtonStyle}"
        Click="BtnHome_Click"/>

                <Button x:Name="BtnOrcamentos" 
                        Content="Novo Orçamento" 
                        FontWeight="SemiBold"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnOrcamentos_Click"/>

                <Button x:Name="BtnHistorico" 
                        Content="Histórico" 
                        FontWeight="SemiBold"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnHistorico_Click"/>

                <Button x:Name="BtnGerenciamento"
                        Content="Gerenciamento"
                        FontWeight="SemiBold"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnGerenciamento_Click"/>
                
                <Button Content="" FontWeight="SemiBold" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>

            <Image Source="/Imagens/AERO_GROUP CONCEPTS_4.png" 
                   Height="193" Width="204"
                   VerticalAlignment="Top" 
                   HorizontalAlignment="Center" 
                   Stretch="Uniform"
                   Panel.ZIndex="1" 
                   Margin="0,19,0,0" 
                   RenderTransformOrigin="0.505,0.09"/>
        </Grid>

        <Grid Grid.Column="1" Margin="15">
            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>